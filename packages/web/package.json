{
  "name": "ikanban-web",
  "version": "0.1.6",
  "description": "iKanban web app",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./vite.js",
    "./index.css": "./src/index.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isomoes/ikanban",
    "directory": "packages/web"
  },
  "scripts": {
    "typecheck": "tsgo -b",
    "type-check": "tsgo -b",
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "bun run test:unit",
    "test:unit": "bun test --preload ./happydom.ts ./src",
    "test:unit:watch": "bun test --watch --preload ./happydom.ts ./src",
    "test:e2e": "playwright test",
    "test:e2e:local": "bun script/e2e-local.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/playwright-report",
    "lint": "eslint \"./src/**/*.{ts,tsx}\" --config ../../eslint.config.js",
    "build:watch": "vite build --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@kobalte/core": "0.13.11",
    "@opencode-ai/sdk": "^1.2.16",
    "@opencode-ai/ui": "workspace:*",
    "@opencode-ai/util": "workspace:*",
    "@shikijs/transformers": "4.0.1",
    "@solid-primitives/active-element": "2.1.5",
    "@solid-primitives/audio": "1.4.4",
    "@solid-primitives/event-bus": "1.1.3",
    "@solid-primitives/i18n": "2.2.1",
    "@solid-primitives/media": "2.3.5",
    "@solid-primitives/resize-observer": "2.1.5",
    "@solid-primitives/scroll": "2.1.5",
    "@solid-primitives/storage": "4.3.4",
    "@solid-primitives/websocket": "1.3.2",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.15.4",
    "@thisbeyond/solid-dnd": "0.7.5",
    "diff": "8.0.3",
    "fuzzysort": "3.1.0",
    "ghostty-web": "0.4.0",
    "luxon": "3.7.2",
    "marked": "17.0.3",
    "marked-shiki": "1.2.1",
    "remeda": "2.33.6",
    "shiki": "4.0.1",
    "solid-js": "1.9.11",
    "solid-list": "0.3.0",
    "tailwindcss": "4.2.1",
    "virtua": "0.48.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.8.3",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.1",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.10",
    "@types/luxon": "3.7.1",
    "@types/node": "25.3.3",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-icons-spritesheet": "3.0.1",
    "vite-plugin-solid": "2.11.10"
  },
  "files": [
    "dist",
    "src",
    "public",
    "package.json",
    "README.md"
  ]
}
