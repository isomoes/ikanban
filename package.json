{
  "name": "ikanban",
  "version": "0.2.8",
  "description": "iKanban - Kanban board powered by OpenCode",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/isomoes/ikanban"
  },
  "scripts": {
    "dev": "bun run --cwd packages/web dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --cwd packages/web build",
    "type-check": "bun run --filter '*' type-check",
    "type-check:web": "bun run --cwd packages/web type-check",
    "lint": "bun run --filter '*' lint",
    "lint:web": "bun run --cwd packages/web lint",
    "clean": "bun run --filter '*' clean",
    "postinstall": "patch-package",
    "dev:web": "bun run --cwd packages/web dev",
    "dev:web:watch": "bun run --cwd packages/web build:watch",
    "start:web": "bun run --cwd packages/web start",
    "bump-version": "node scripts/bump-version.mjs"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "typescript": "~5.9.3"
  }
}
